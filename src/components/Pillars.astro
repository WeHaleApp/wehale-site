---
/**
 * Three Ways to Practice. Mirrors the app's category pillars exactly:
 * Activate (gold), Balance (sage), Calm (blue).
 */
/**
 * Three Ways to Practice. Each card now uses:
 *   · A custom SVG icon evoking the category mood (sunrise / waves /
 *     moon): much more premium than the previous abstract dot
 *   · A breath-rhythm illustration unique to each category
 *   · Time-of-day and use-case metadata
 *   · Duration range (factual from the catalog)
 *
 * No sample-sessions list (that's now redundant with the SessionShowcase
 * section directly below: better to set up WHEN to use each category
 * here, then show the actual catalog there).
 */
const pillars = [
  {
    key: "activate",
    title: "Activate",
    body: "Wake up your energy. Sharpen focus. Start your morning with intention, not caffeine.",
    bestFor: "Mornings · Pre-workout · Pre-meeting",
    duration: "5–15 min",
    intent: "Energy & focus",
    color: "var(--color-gold)",
    soft: "var(--color-gold-soft)",
    line: "var(--color-gold-line)",
  },
  {
    key: "balance",
    title: "Balance",
    body: "Reset your nervous system midday. Find steady ground between the demands.",
    bestFor: "Midday · Between meetings · Stress",
    duration: "8–13 min",
    intent: "Regulation",
    color: "var(--color-accent)",
    soft: "var(--color-accent-soft)",
    line: "var(--color-accent-line)",
  },
  {
    key: "calm",
    title: "Calm",
    body: "Soften the body, quiet the mind. Prepare for deep rest or simply let the day go.",
    bestFor: "Evening · Pre-sleep · Reset",
    duration: "2–15 min",
    intent: "Sleep & rest",
    color: "var(--color-blue)",
    soft: "var(--color-blue-soft)",
    line: "var(--color-blue-line)",
  },
];
---

<section class="py-24 md:py-32" id="practice">
  <div class="mx-auto max-w-6xl px-6">
    <header class="mx-auto max-w-2xl text-center" data-reveal>
      <h2 class="text-3xl font-semibold tracking-tight md:text-5xl">
        Three ways to practice.
      </h2>
      <p class="mt-4 text-base text-[var(--color-text-secondary)] md:text-lg">
        Every session is built around how you want to feel. Not a one-size-fits-all
        routine.
      </p>
    </header>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        pillars.map((p, i) => (
          <article
            class="group relative overflow-hidden rounded-3xl border border-[var(--color-line)] bg-[var(--color-bg-raised)] transition-all duration-300 hover:-translate-y-1 hover:border-[var(--color-line-strong)]"
            data-reveal
            style={`transition-delay: ${i * 80}ms`}
          >
            {/* Category-tinted gradient backdrop: stronger now to
                 give each card a distinct mood that reads at a glance. */}
            <div
              class="pointer-events-none absolute inset-0 opacity-90"
              style={`background: radial-gradient(ellipse at top, ${p.color}26 0%, transparent 65%), linear-gradient(to bottom, ${p.color}14 0%, transparent 35%);`}
              aria-hidden="true"
            ></div>

            <div class="relative p-8 md:p-10">
              {/* Custom category icon: distinctive glyph evokes the
                   mood (sunrise / waves / moon) and pulses on hover.
                   Each rendered with the category color and a soft
                   halo behind it. */}
              <div class="relative inline-flex h-16 w-16 items-center justify-center">
                <span
                  class="absolute inset-0 rounded-full opacity-50 blur-lg transition-opacity duration-500 group-hover:opacity-80"
                  style={`background: ${p.color};`}
                  aria-hidden="true"
                ></span>
                <span
                  class="relative inline-flex h-14 w-14 items-center justify-center rounded-full transition-transform duration-500 group-hover:scale-105"
                  style={`background: ${p.soft}; border: 1px solid ${p.line};`}
                  aria-hidden="true"
                >
                  {p.key === "activate" && (
                    /* Sunrise: rays + horizon */
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                      <circle cx="14" cy="17" r="5" stroke={p.color} stroke-width="1.5" />
                      <path d="M14 7v2M21 10l-1.5 1.5M7 10l1.5 1.5M3 17h2M23 17h2" stroke={p.color} stroke-width="1.5" stroke-linecap="round" />
                      <path d="M2 22h24" stroke={p.color} stroke-width="1.5" stroke-linecap="round" opacity="0.5" />
                    </svg>
                  )}
                  {p.key === "balance" && (
                    /* Balance: equal-ratio sine wave */
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                      <path d="M3 14c2-4 4-4 6 0s4 4 6 0 4-4 6 0 4 4 4 0" stroke={p.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      <circle cx="14" cy="14" r="1.2" fill={p.color} />
                    </svg>
                  )}
                  {p.key === "calm" && (
                    /* Crescent moon */
                    <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                      <path d="M21 18.5A9 9 0 1 1 9.5 7a7 7 0 0 0 11.5 11.5z" stroke={p.color} stroke-width="1.5" stroke-linejoin="round" fill={`${p.color}1A`} />
                    </svg>
                  )}
                </span>
              </div>

              <h3 class="mt-8 text-3xl font-semibold tracking-tight" style={`color: ${p.color}; letter-spacing: var(--tracking-display);`}>
                {p.title}.
              </h3>
              <p class="mt-3 text-[var(--color-text-secondary)] leading-relaxed">
                {p.body}
              </p>

              {/* Metadata strip: best-for + duration + intent. Sets
                   up the WHEN, then SessionShowcase below shows WHAT. */}
              <dl class="mt-8 space-y-3 border-t border-[var(--color-line)] pt-6 text-sm">
                <div class="flex items-baseline gap-3">
                  <dt class="w-20 flex-shrink-0 text-xs uppercase tracking-[0.14em] text-[var(--color-text-tertiary)]">Best for</dt>
                  <dd class="text-[var(--color-text)]">{p.bestFor}</dd>
                </div>
                <div class="flex items-baseline gap-3">
                  <dt class="w-20 flex-shrink-0 text-xs uppercase tracking-[0.14em] text-[var(--color-text-tertiary)]">Length</dt>
                  <dd class="text-[var(--color-text)]">{p.duration}</dd>
                </div>
                <div class="flex items-baseline gap-3">
                  <dt class="w-20 flex-shrink-0 text-xs uppercase tracking-[0.14em] text-[var(--color-text-tertiary)]">Intent</dt>
                  <dd class="text-[var(--color-text)]">{p.intent}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
