---
/**
 * Three Ways to Practice. Mirrors the app's category pillars exactly:
 * Activate (gold), Balance (sage), Calm (blue).
 */
/**
 * Three Ways to Practice — premium card style. Each card has:
 *   · A lifestyle hero image at the top, full-bleed inside the card
 *     (drawn from the Marketing/Human/Nature sets to evoke the mood)
 *   · A coloured accent dot for category recognition
 *   · A short title and body
 *
 * Image choices map to mood:
 *   Activate → man-running (energy, dawn)
 *   Balance  → woman-meditation (centered, grounded)
 *   Calm     → man-dusk (settling, evening)
 */
const pillars = [
  {
    key: "activate",
    title: "Activate",
    body: "Wake up your energy. Sharpen focus. Start your morning with intention, not caffeine.",
    image: "/assets/images/marketing/man-running.png",
    color: "var(--color-gold)",
    soft: "var(--color-gold-soft)",
    line: "var(--color-gold-line)",
  },
  {
    key: "balance",
    title: "Balance",
    body: "Reset your nervous system midday. Find steady ground between the demands.",
    image: "/assets/images/marketing/woman-meditation.png",
    color: "var(--color-accent)",
    soft: "var(--color-accent-soft)",
    line: "var(--color-accent-line)",
  },
  {
    key: "calm",
    title: "Calm",
    body: "Soften the body, quiet the mind. Prepare for deep rest or simply let the day go.",
    image: "/assets/images/marketing/man-dusk.png",
    color: "var(--color-blue)",
    soft: "var(--color-blue-soft)",
    line: "var(--color-blue-line)",
  },
];
---

<section class="py-24 md:py-32" id="practice">
  <div class="mx-auto max-w-6xl px-6">
    <header class="mx-auto max-w-2xl text-center" data-reveal>
      <h2 class="text-3xl font-semibold tracking-tight md:text-5xl">
        Three ways to practice.
      </h2>
      <p class="mt-4 text-base text-[var(--color-text-secondary)] md:text-lg">
        Every session is built around how you want to feel — not a one-size-fits-all
        routine.
      </p>
    </header>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        pillars.map((p, i) => (
          <article
            class="group relative overflow-hidden rounded-3xl border border-[var(--color-line)] bg-[var(--color-bg-raised)] transition-transform duration-300 hover:-translate-y-1"
            data-reveal
            style={`transition-delay: ${i * 80}ms`}
          >
            {/* Lifestyle hero — full-bleed top of card with gradient
                 fade into the card body for legibility. */}
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={p.image}
                alt=""
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div
                class="absolute inset-0"
                style={`background: linear-gradient(to bottom, transparent 40%, ${p.color}15 70%, var(--color-bg-raised));`}
              ></div>
              {/* Category eyebrow inside image, top-left */}
              <span
                class="absolute left-5 top-5 inline-flex items-center gap-2 rounded-full px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em]"
                style={`background: rgba(9,15,29,0.65); color: ${p.color}; backdrop-filter: blur(8px);`}
              >
                <span class="h-1.5 w-1.5 rounded-full" style={`background: ${p.color}`}></span>
                {p.title}
              </span>
            </div>

            <div class="px-7 pb-8 pt-5">
              <h3 class="text-2xl font-semibold" style={`color: ${p.color}`}>
                {p.title}.
              </h3>
              <p class="mt-3 text-[var(--color-text-secondary)] leading-relaxed">
                {p.body}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
