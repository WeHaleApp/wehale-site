---
/**
 * Three Ways to Practice. Mirrors the app's category pillars exactly:
 * Activate (gold), Balance (sage), Calm (blue).
 */
/**
 * Three Ways to Practice. Each card uses a category-tinted gradient
 * backdrop + a sample-sessions list to feel substantive without leaning
 * on hero imagery (the Marketing photography set is ad-creative with
 * branding burned in, not clean stock photography we can repurpose).
 *
 * Sample sessions are illustrative — pulled from real session titles in
 * the catalog so they read as authentic, not invented.
 */
const pillars = [
  {
    key: "activate",
    title: "Activate",
    body: "Wake up your energy. Sharpen focus. Start your morning with intention, not caffeine.",
    sample: ["Ignite Your Focus", "Echoes of Strength", "The Conscious Morning"],
    color: "var(--color-gold)",
    soft: "var(--color-gold-soft)",
    line: "var(--color-gold-line)",
  },
  {
    key: "balance",
    title: "Balance",
    body: "Reset your nervous system midday. Find steady ground between the demands.",
    sample: ["Coherent Heart", "Box Breath", "Steady Ground"],
    color: "var(--color-accent)",
    soft: "var(--color-accent-soft)",
    line: "var(--color-accent-line)",
  },
  {
    key: "calm",
    title: "Calm",
    body: "Soften the body, quiet the mind. Prepare for deep rest or simply let the day go.",
    sample: ["Into Stillness", "Nighttime Serenity", "4-7-8 Practice"],
    color: "var(--color-blue)",
    soft: "var(--color-blue-soft)",
    line: "var(--color-blue-line)",
  },
];
---

<section class="py-24 md:py-32" id="practice">
  <div class="mx-auto max-w-6xl px-6">
    <header class="mx-auto max-w-2xl text-center" data-reveal>
      <h2 class="text-3xl font-semibold tracking-tight md:text-5xl">
        Three ways to practice.
      </h2>
      <p class="mt-4 text-base text-[var(--color-text-secondary)] md:text-lg">
        Every session is built around how you want to feel — not a one-size-fits-all
        routine.
      </p>
    </header>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {
        pillars.map((p, i) => (
          <article
            class="group relative overflow-hidden rounded-3xl border border-[var(--color-line)] bg-[var(--color-bg-raised)] transition-transform duration-300 hover:-translate-y-1"
            data-reveal
            style={`transition-delay: ${i * 80}ms`}
          >
            {/* Category-tinted gradient backdrop — soft glow that
                 evokes the mood of each pillar without leaning on a
                 photographic hero. The gradient sits behind everything
                 else; pointer-events-none so it never interferes. */}
            <div
              class="pointer-events-none absolute inset-0 opacity-90"
              style={`background: radial-gradient(ellipse at top, ${p.color}1F 0%, transparent 60%), linear-gradient(to bottom, ${p.color}10 0%, transparent 30%);`}
              aria-hidden="true"
            ></div>

            <div class="relative p-8 md:p-10">
              {/* Big category dot with soft halo */}
              <span
                class="relative inline-flex h-14 w-14 items-center justify-center rounded-full"
                style={`background: ${p.soft}; box-shadow: 0 0 40px ${p.color}30;`}
                aria-hidden="true"
              >
                <span
                  class="absolute inset-0 rounded-full"
                  style={`border: 1px solid ${p.line};`}
                ></span>
                <span class="h-3 w-3 rounded-full" style={`background: ${p.color}`}></span>
              </span>

              <h3 class="mt-7 text-3xl font-semibold tracking-tight" style={`color: ${p.color}`}>
                {p.title}.
              </h3>
              <p class="mt-3 text-[var(--color-text-secondary)] leading-relaxed">
                {p.body}
              </p>

              {/* Sample sessions — communicates that the catalog is
                   real and gives a flavor of what's inside. */}
              <ul class="mt-8 space-y-2 border-t border-[var(--color-line)] pt-6 text-sm">
                {p.sample.map((s) => (
                  <li class="flex items-center gap-3 text-[var(--color-text-secondary)]">
                    <svg
                      class="h-3 w-3 flex-shrink-0"
                      style={`color: ${p.color}`}
                      viewBox="0 0 12 12"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <circle cx="6" cy="6" r="6" />
                    </svg>
                    {s}
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
