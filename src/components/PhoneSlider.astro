---
/**
 * Inside the App — phone slider. Auto-advances, pauses on hover/focus.
 * Pure-vanilla JS for now (no React/Svelte island needed at this scale).
 *
 * Screenshots: pulled from the existing site's UI assets which are
 * already optimized (webp + jpg). Swap to AppStoreNew renders later for
 * higher-fidelity captures.
 */
// Fresh App Store-grade screenshots from 00-Inbox/AppStoreNew at 1320×2868.
// Aspect ratio matches iPhone 17 Pro Max (the device they were captured on)
// — 1320/2868 ≈ 0.46. The frame below uses that ratio so screens fit edge
// to edge with no clipping.
const slides = [
  {
    src: "/assets/images/screens/01-home.png",
    alt: "WeHale home — your daily practice",
    caption: "Your daily practice — front and center",
  },
  {
    src: "/assets/images/screens/02-practice.png",
    alt: "Practice tab — browse the session library",
    caption: "Twenty-five guided sessions, all in one place",
  },
  {
    src: "/assets/images/screens/03-player.png",
    alt: "Player — full-bleed cinematic backgrounds",
    caption: "Press play. Cinematic. Distraction-free.",
  },
  {
    src: "/assets/images/screens/04-progress.png",
    alt: "Progress — weekly goal ring and streak",
    caption: "Track your rhythm without the streak guilt",
  },
  {
    src: "/assets/images/screens/05-mood.png",
    alt: "Home — mood-based session recommendations",
    caption: "Tell it how you feel. It picks the right session.",
  },
];
---

<section
  class="relative overflow-hidden py-24 md:py-40"
  id="product"
>
  <!-- Layered ambient glows. Two radial gradients (sage tinted) + a faint
       gold to make the section feel alive, not just dark. Stays behind
       all content; pointer-events disabled. -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/2 h-[900px] w-[900px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-50 blur-3xl"
    style="background: radial-gradient(circle, rgba(124,181,162,0.22), transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute left-[10%] top-[20%] h-[300px] w-[300px] rounded-full opacity-30 blur-3xl"
    style="background: radial-gradient(circle, rgba(232,168,78,0.18), transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute right-[8%] bottom-[15%] h-[400px] w-[400px] rounded-full opacity-40 blur-3xl"
    style="background: radial-gradient(circle, rgba(147,165,207,0.16), transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <header class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="eyebrow">Inside the app</p>
      <h2 class="mt-4 text-4xl font-semibold tracking-tight md:text-6xl" style="letter-spacing: var(--tracking-display);">
        Calm from the<br />first tap.
      </h2>
      <p class="mx-auto mt-6 max-w-lg text-base text-[var(--color-text-secondary)] md:text-lg">
        Dark interface, cinematic backgrounds, no clutter. Every screen built to
        match the practice.
      </p>
    </header>

    <!-- Phone presentation: a single dominant phone in the center with
         two subtle background phones in perspective on either side. The
         center phone is the only interactive one (slides via dots).
         Decorative phones are aria-hidden + lower opacity. -->
    <div class="relative mt-20 flex items-center justify-center" data-reveal data-phone-slider>
      <!-- Decorative phone — left, behind -->
      <div
        class="hidden lg:block pointer-events-none absolute left-[6%] top-[8%] aspect-[1320/2868] w-[300px] -rotate-[8deg] overflow-hidden rounded-[42px] border border-[var(--color-line-strong)] bg-[var(--color-bg-raised)] p-[5px] opacity-50 shadow-[0_30px_80px_-20px_rgba(0,0,0,0.6)]"
        aria-hidden="true"
      >
        <div class="h-full w-full overflow-hidden rounded-[37px] bg-black">
          <img src="/assets/images/screens/02-practice.png" alt="" loading="lazy" class="h-full w-full object-cover" />
        </div>
      </div>

      <!-- Decorative phone — right, behind -->
      <div
        class="hidden lg:block pointer-events-none absolute right-[6%] top-[10%] aspect-[1320/2868] w-[300px] rotate-[8deg] overflow-hidden rounded-[42px] border border-[var(--color-line-strong)] bg-[var(--color-bg-raised)] p-[5px] opacity-50 shadow-[0_30px_80px_-20px_rgba(0,0,0,0.6)]"
        aria-hidden="true"
      >
        <div class="h-full w-full overflow-hidden rounded-[37px] bg-black">
          <img src="/assets/images/screens/03-player.png" alt="" loading="lazy" class="h-full w-full object-cover" />
        </div>
      </div>

      <!-- Hero phone — interactive, center, sized larger for impact -->
      <div class="relative aspect-[1320/2868] w-[300px] md:w-[400px] rounded-[56px] border border-[var(--color-line-strong)] bg-[var(--color-bg-raised)] p-[7px] shadow-[0_60px_120px_-30px_rgba(0,0,0,0.8)] z-10">
        <div class="relative h-full w-full overflow-hidden rounded-[49px] bg-black">
          {
            slides.map((s, i) => (
              <img
                src={s.src}
                alt={s.alt}
                width="1320"
                height="2868"
                loading={i === 0 ? "eager" : "lazy"}
                class:list={[
                  "absolute inset-0 h-full w-full object-cover transition-opacity duration-500",
                  i === 0 ? "opacity-100" : "opacity-0",
                ]}
                data-slide-index={i}
              />
            ))
          }
        </div>
      </div>
    </div>

    <p class="mt-12 text-center text-base text-[var(--color-text-secondary)] md:text-lg" data-slide-caption>
      {slides[0].caption}
    </p>

    <div class="mt-6 flex items-center justify-center gap-2" role="tablist" aria-label="App screens">
      {
        slides.map((_, i) => (
          <button
            type="button"
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-label={`Show screen ${i + 1}`}
            data-slide-dot={i}
            class:list={[
              "h-1.5 rounded-full transition-all duration-300",
              i === 0
                ? "w-8 bg-[var(--color-text)]"
                : "w-2 bg-[var(--color-text-muted)] hover:bg-[var(--color-text-tertiary)]",
            ]}
          />
        ))
      }
    </div>
  </div>
</section>

<script
  is:inline
  define:vars={{ captions: slides.map((s) => s.caption) }}
>
  (function () {
    const slider = document.querySelector("[data-phone-slider]");
    if (!slider) return;
    const slides = slider.querySelectorAll("[data-slide-index]");
    const dots = slider.querySelectorAll("[data-slide-dot]");
    const captionEl = slider.querySelector("[data-slide-caption]");
    let active = 0;
    let timer = 0;
    const interval = 4500;

    function show(i) {
      slides.forEach((el, idx) => {
        el.classList.toggle("opacity-100", idx === i);
        el.classList.toggle("opacity-0", idx !== i);
      });
      dots.forEach((dot, idx) => {
        const on = idx === i;
        dot.setAttribute("aria-selected", on ? "true" : "false");
        dot.classList.toggle("w-8", on);
        dot.classList.toggle("bg-[var(--color-text)]", on);
        dot.classList.toggle("w-2", !on);
        dot.classList.toggle("bg-[var(--color-text-muted)]", !on);
      });
      if (captionEl) captionEl.textContent = captions[i] || "";
      active = i;
    }

    function next() {
      show((active + 1) % slides.length);
    }

    function start() {
      stop();
      timer = window.setInterval(next, interval);
    }
    function stop() {
      if (timer) clearInterval(timer);
      timer = 0;
    }

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        show(i);
        start();
      });
    });
    slider.addEventListener("mouseenter", stop);
    slider.addEventListener("mouseleave", start);
    slider.addEventListener("focusin", stop);
    slider.addEventListener("focusout", start);

    // Respect reduced-motion
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (!reduced) start();
  })();
</script>
