---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "WeHale for Investors";
const description =
  "WeHale is a breathwork app for people who don't meditate. Investor information, traction, team, and contact.";

// PLACEHOLDER — swap with real numbers as they materialize post-launch.
const stats = [
  { label: "Sessions in catalog", value: "25+", note: "Across Activate, Balance, Calm" },
  { label: "Founding team", value: "6", note: "Product, design, brand, content" },
  { label: "Launch", value: "May 2026", note: "iOS — Android in roadmap" },
];

const team = [
  { initial: "I", name: "Isak Gustafsson", role: "Founder", description: "Product, vision, day-to-day", color: "var(--color-accent)" },
  { initial: "J", name: "Joe", role: "Design", description: "UX, visual, brand expression in product", color: "var(--color-blue)" },
  { initial: "M", name: "Martin Wikfalk", role: "Brand & copy", description: "Brand voice, positioning, messaging", color: "var(--color-gold)" },
  { initial: "E", name: "Edvin", role: "Content", description: "Session curation, community, copy", color: "var(--color-accent)" },
  { initial: "P", name: "Philip Sigfridsson", role: "Strategy", description: "Operations and partnerships", color: "var(--color-blue)" },
  { initial: "S", name: "Simon & Sergej", role: "Creative", description: "Social and creative production", color: "var(--color-gold)" },
];

const differentiators = [
  {
    title: "Technique-first",
    body:
      "Every session is built around a real breathwork technique with measurable physiological intent — not a generic meditation track with breathing cues added on.",
  },
  {
    title: "Calm brand, no hype",
    body:
      "We don't promise transformation. We don't shout. The brand reads like the practice itself: warm, grounded, restrained. That tone is rare in this category and a real differentiator.",
  },
  {
    title: "Science-led, accessibly",
    body:
      "Real citations, real mechanisms (HRV, vagal tone, parasympathetic activation), explained in plain language. We over-deliver on credibility while staying readable.",
  },
];
---

<BaseLayout title={title} description={description} solidHeader>
  <!-- Section 1: Positioning -->
  <section class="pt-32 pb-20 md:pt-44 md:pb-28">
    <div class="mx-auto max-w-5xl px-6">
      <p class="eyebrow" data-reveal>Investors</p>
      <h1
        class="mt-6 max-w-3xl text-4xl font-semibold leading-tight md:text-6xl"
        style="letter-spacing: var(--tracking-display);"
        data-reveal
      >
        A breathwork practice for people who don't meditate.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-[var(--color-text-secondary)] md:text-xl" data-reveal>
        WeHale is an iOS-first breathwork app launching May 2026. We're building
        the calmest, most credible app in a category that's been dominated by
        hype.
      </p>
      <div class="mt-10 flex flex-wrap gap-3" data-reveal>
        <a
          href="mailto:isak@wehale.io"
          class="inline-flex items-center gap-2 rounded-full bg-[var(--color-text)] px-6 py-3 text-sm font-semibold text-[var(--color-bg)] hover:bg-[var(--color-accent)] transition-colors"
        >
          Email Isak
        </a>
        <a
          href="#team"
          class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line-strong)] px-6 py-3 text-sm font-medium text-[var(--color-text)] hover:bg-[var(--color-bg-raised)] transition-colors"
        >
          Meet the team
        </a>
      </div>
    </div>
  </section>

  <!-- Section 2: Stats -->
  <section class="bg-[var(--color-bg-alt)] py-16 md:py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-6 md:grid-cols-3">
        {
          stats.map((s, i) => (
            <div
              class="rounded-3xl border border-[var(--color-line)] bg-[var(--color-bg)] p-8"
              data-reveal
              style={`transition-delay: ${i * 80}ms`}
              data-placeholder="stat"
            >
              <div class="text-5xl font-semibold tracking-tight" style="letter-spacing: var(--tracking-display);">
                {s.value}
              </div>
              <div class="mt-3 text-sm font-medium text-[var(--color-text)]">{s.label}</div>
              <div class="mt-1 text-xs text-[var(--color-text-tertiary)]">{s.note}</div>
            </div>
          ))
        }
      </div>
      <p class="mt-8 text-center text-xs text-[var(--color-text-tertiary)]">
        Live traction metrics published here post-launch as they materialize.
      </p>
    </div>
  </section>

  <!-- Section 3: Differentiators -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <header class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-semibold tracking-tight md:text-5xl">What makes us distinct.</h2>
      </header>

      <div class="mt-16 grid gap-6 md:grid-cols-3">
        {
          differentiators.map((d, i) => (
            <article
              class="rounded-3xl border border-[var(--color-line)] bg-[var(--color-bg-raised)] p-8"
              data-reveal
              style={`transition-delay: ${i * 80}ms`}
            >
              <h3 class="text-xl font-semibold">{d.title}</h3>
              <p class="mt-3 text-[var(--color-text-secondary)]">{d.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 4: Team -->
  <section class="bg-[var(--color-bg-alt)] py-24 md:py-32" id="team">
    <div class="mx-auto max-w-6xl px-6">
      <header class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-semibold tracking-tight md:text-5xl">The team.</h2>
        <p class="mt-4 text-base text-[var(--color-text-secondary)]">
          Small, focused, all in.
        </p>
      </header>

      <div class="mt-16 grid gap-6 sm:grid-cols-2 md:grid-cols-3" data-reveal>
        {
          team.map((m) => (
            <article
              class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-bg)] p-6"
              data-placeholder="team-photo"
            >
              <span
                class="inline-flex h-12 w-12 items-center justify-center rounded-full text-lg font-semibold text-[var(--color-bg)]"
                style={`background: ${m.color}`}
                aria-hidden="true"
              >
                {m.initial}
              </span>
              <h3 class="mt-4 text-lg font-semibold">{m.name}</h3>
              <p class="text-sm text-[var(--color-text-tertiary)]">{m.role}</p>
              <p class="mt-3 text-sm text-[var(--color-text-secondary)]">
                {m.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 5: Press kit -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-semibold md:text-4xl" data-reveal>Press kit.</h2>
      <p class="mt-4 text-base text-[var(--color-text-secondary)]" data-reveal>
        Logo files, brand colors, hero screenshots, and 100-word boilerplate.
        Available on request — drop us a line.
      </p>
      <a
        href="mailto:hello@wehale.io?subject=WeHale press kit"
        class="mt-8 inline-flex items-center gap-2 rounded-full border border-[var(--color-line-strong)] px-6 py-3 text-sm font-medium hover:bg-[var(--color-bg-raised)] transition-colors"
        data-reveal
      >
        Request press kit
      </a>
    </div>
  </section>

  <!-- Section 6: Contact -->
  <section class="bg-[var(--color-bg-alt)] py-24 md:py-32">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-semibold md:text-4xl" data-reveal>Let's talk.</h2>
      <p class="mt-4 text-base text-[var(--color-text-secondary)]" data-reveal>
        We're not raising actively, but we're always glad to meet thoughtful
        investors who care about the category.
      </p>
      <a
        href="mailto:isak@wehale.io?subject=WeHale — investor intro"
        class="mt-10 inline-flex items-center gap-2 rounded-full bg-[var(--color-text)] px-6 py-3 text-sm font-semibold text-[var(--color-bg)] hover:bg-[var(--color-accent)] transition-colors"
        data-reveal
      >
        Email Isak directly
      </a>
    </div>
  </section>
</BaseLayout>
