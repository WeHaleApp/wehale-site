---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalLayout from "../components/LegalLayout.astro";

const title = "Terms of Use — WeHale";
const description =
  "Terms governing your use of WeHale's mobile app and website.";
---

<BaseLayout title={title} description={description} solidHeader>
  <LegalLayout heading="Terms of Use" effective="March 12, 2026">
    <p>
      These terms govern your use of the WeHale mobile application and website
      (collectively, the "Service"). By using the Service, you agree to these
      terms.
    </p>

    <h2>1. The service</h2>
    <p>
      WeHale provides guided breathwork audio sessions, progress tracking, and
      related wellness features. The Service is for personal, non-commercial use.
    </p>

    <h2>2. Accounts</h2>
    <p>
      You must create an account to access most features. You are responsible
      for maintaining the security of your account credentials. You must be at
      least 13 years old to create an account.
    </p>

    <h2>3. Subscriptions and payments</h2>
    <ul>
      <li>Some content requires a paid subscription (monthly or annual).</li>
      <li>Subscriptions are billed through the Apple App Store and managed via your Apple ID.</li>
      <li>Subscriptions auto-renew unless cancelled at least 24 hours before the end of the current period.</li>
      <li>Refunds are handled by Apple according to their refund policy.</li>
    </ul>

    <h2>4. Health disclaimer</h2>
    <p>
      WeHale is a wellness tool, not a medical device. Our sessions are not a
      substitute for professional medical advice, diagnosis, or treatment. If
      you have a medical condition (including but not limited to cardiovascular
      conditions, epilepsy, or respiratory disorders), consult a healthcare
      professional before practising breathwork.
    </p>
    <p>
      Some techniques involve breath holds or rapid breathing that may cause
      dizziness or lightheadedness. Always practise in a safe position and stop
      if you feel unwell.
    </p>

    <h2>5. Content and intellectual property</h2>
    <p>
      All audio sessions, videos, images, text, and other content in the Service
      are owned by WeHale or our licensors. You may not copy, redistribute, or
      commercially exploit any content without our written permission.
    </p>

    <h2>6. Acceptable use</h2>
    <p>You agree not to:</p>
    <ul>
      <li>Share your account with others or circumvent access restrictions.</li>
      <li>Record, download, or redistribute session audio.</li>
      <li>Reverse-engineer the app or its APIs.</li>
      <li>Use the Service for any unlawful purpose.</li>
    </ul>

    <h2>7. Termination</h2>
    <p>
      You may delete your account at any time by contacting{" "}
      <a href="mailto:hello@wehale.io">hello@wehale.io</a>. We may suspend or
      terminate accounts that violate these terms.
    </p>

    <h2>8. Limitation of liability</h2>
    <p>
      To the maximum extent permitted by law, WeHale is provided "as is" without
      warranties of any kind. We are not liable for any indirect, incidental, or
      consequential damages arising from your use of the Service.
    </p>

    <h2>9. Governing law</h2>
    <p>
      These terms are governed by the laws of Sweden. Any disputes shall be
      resolved in the courts of Stockholm, Sweden.
    </p>

    <h2>10. Changes</h2>
    <p>
      We may update these terms from time to time. Material changes will be
      communicated via the app or email. Continued use after changes constitutes
      acceptance.
    </p>

    <h2>11. Contact</h2>
    <p>
      Questions? Email{" "}
      <a href="mailto:hello@wehale.io">hello@wehale.io</a>.
    </p>
  </LegalLayout>
</BaseLayout>
