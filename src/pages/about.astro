---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsletterForm from "../components/NewsletterForm.astro";

const title = "About WeHale";
const description =
  "The team and conviction behind WeHale, a breathwork app for people who don't meditate.";

// Three co-founders: equal billing. Bios mirror the investor page but
// in a slightly warmer register for the public site.
const founders = [
  {
    initial: "I",
    name: "Isak Gustafsson",
    role: "Co-founder",
    bio: "Computer science background and ten years at Precis, Sweden's largest media-tech agency, working with global app teams. Builds the app and runs growth.",
    color: "var(--color-accent)",
  },
  {
    initial: "E",
    name: "Edvin",
    role: "Co-founder",
    bio: "Years of personal breathwork practice and live group sessions. Curates the catalog and teaches the techniques behind it.",
    color: "var(--color-blue)",
  },
  {
    initial: "P",
    name: "Philip Sigfridsson",
    role: "Co-founder",
    bio: "Years of breathwork practice and group facilitation. Anchors the product to the practice as it actually works.",
    color: "var(--color-gold)",
  },
];

// Full lineup grid below: founders + advisor, compact (no bios).
const team = [
  { initial: "I", name: "Isak Gustafsson", role: "Co-founder", color: "var(--color-accent)" },
  { initial: "E", name: "Edvin", role: "Co-founder", color: "var(--color-blue)" },
  { initial: "P", name: "Philip Sigfridsson", role: "Co-founder", color: "var(--color-gold)" },
  { initial: "M", name: "Martin Wikfalk", role: "Advisor", color: "var(--color-accent)" },
];
---

<BaseLayout title={title} description={description} solidHeader>
  <!-- Section 1: Founders. Three co-founders, equal billing -->
  <section class="pt-32 pb-24 md:pt-44 md:pb-32">
    <div class="mx-auto max-w-5xl px-6">
      <p class="eyebrow" data-reveal>About</p>
      <h1
        class="mt-6 max-w-3xl text-4xl font-semibold leading-tight md:text-6xl"
        style="letter-spacing: var(--tracking-display);"
        data-reveal
      >
        Built from the breath up.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-[var(--color-text-secondary)] md:text-xl" data-reveal>
        Three co-founders started WeHale because the breathwork app we wanted
        didn't exist: credible, calm, technique-first.
      </p>

      <div class="mt-16 grid gap-6 md:grid-cols-3">
        {
          founders.map((m, i) => (
            <article
              class="rounded-3xl border border-[var(--color-line)] bg-[var(--color-bg-raised)] p-6 md:p-8"
              data-reveal
              style={`transition-delay: ${i * 80}ms`}
              data-placeholder="founder-photo"
            >
              <span
                class="inline-flex h-14 w-14 items-center justify-center rounded-full text-xl font-semibold text-[var(--color-bg)]"
                style={`background: ${m.color}`}
                aria-hidden="true"
              >
                {m.initial}
              </span>
              <h2 class="mt-5 text-xl font-semibold">{m.name}</h2>
              <p class="text-sm uppercase tracking-[0.12em] text-[var(--color-text-tertiary)]">
                {m.role}
              </p>
              <p class="mt-4 text-base leading-relaxed text-[var(--color-text-secondary)]">
                {m.bio}
              </p>
            </article>
          ))
        }
      </div>

      <p class="mt-10 text-sm text-[var(--color-text-tertiary)]" data-reveal>
        Reach the team at{" "}
        <a
          href="mailto:hello@wehale.io"
          class="text-[var(--color-accent)] hover:underline"
        >
          hello@wehale.io
        </a>
        .
      </p>
    </div>
  </section>

  <!-- Section 2: Why breathwork specifically -->
  <section class="bg-[var(--color-bg-alt)] py-24 md:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-semibold tracking-tight md:text-5xl" data-reveal>
        Why breathwork specifically.
      </h2>
      <div class="mx-auto mt-10 space-y-6 text-left text-lg text-[var(--color-text-secondary)]" data-reveal>
        <p>
          Most wellness apps treat the breath as a feature. We treat it as the
          foundation. Every session is built around a real technique with a real
          physiological intent. Not a generic relaxation track with breathing
          cues bolted on.
        </p>
        <p>
          Five minutes a day, done with attention, compounds. That's the whole
          thesis. The app exists to make those five minutes easy enough to
          actually do.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 3: The team -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-6xl px-6">
      <header class="mx-auto max-w-2xl text-center" data-reveal>
        <h2 class="text-3xl font-semibold tracking-tight md:text-5xl">The team.</h2>
        <p class="mt-4 text-base text-[var(--color-text-secondary)] md:text-lg">
          Small group, focused work. We'll add real photos once everyone's
          camera-ready.
        </p>
      </header>

      <div class="mt-16 grid gap-6 sm:grid-cols-2 md:grid-cols-4" data-reveal>
        {
          team.map((m) => (
            <article
              class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-bg-raised)] p-6"
              data-placeholder="team-photo"
            >
              <span
                class="inline-flex h-12 w-12 items-center justify-center rounded-full text-lg font-semibold text-[var(--color-bg)]"
                style={`background: ${m.color}`}
                aria-hidden="true"
              >
                {m.initial}
              </span>
              <h3 class="mt-4 text-lg font-semibold">{m.name}</h3>
              <p class="text-sm text-[var(--color-text-tertiary)]">{m.role}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Section 4: Where -->
  <section class="bg-[var(--color-bg-alt)] py-24 md:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-2xl font-semibold md:text-3xl" data-reveal>
        Based in Varberg, Sweden.
      </h2>
      <p class="mt-4 text-base text-[var(--color-text-secondary)] md:text-lg" data-reveal>
        Built locally, for anyone who wants a calmer nervous system on the other
        side of five quiet minutes.
      </p>
    </div>
  </section>

  <!-- Section 5: Reach out -->
  <section class="py-24 md:py-32">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-semibold md:text-4xl" data-reveal>Reach out.</h2>
      <p class="mt-4 text-base text-[var(--color-text-secondary)]" data-reveal>
        Press, partnerships, investors, or just hello. We read everything.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4" data-reveal>
        <a
          href="mailto:hello@wehale.io"
          class="rounded-full bg-[var(--color-text)] px-6 py-3 text-sm font-semibold text-[var(--color-bg)] hover:bg-[var(--color-accent)] transition-colors"
        >
          hello@wehale.io
        </a>
        <div class="mt-4 w-full max-w-md">
          <NewsletterForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
